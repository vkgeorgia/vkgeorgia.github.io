# Скопируйте в файл `.env` в корне репозитория (`.env` в .gitignore).
#
# Neon: для локальных скриптов в ЭТОМ репозитории строка подключения задаётся
# только здесь — через переменную NEON_DATABASE_URL.
# На проде (Cloud Run) тот же DSN задаётся в переменных окружения сервиса
# в репозитории/консоли Jeeves, не в vkgeorgia.github.io.

NEON_DATABASE_URL=postgresql://USER:PASSWORD@YOUR-ENDPOINT.neon.tech/neondb?sslmode=require
GEMINI_API_KEY=

# Опционально, для curl-примеров в терминале (не читается Jekyll по умолчанию):
# CLOUD_RUN_BACKEND_URL=https://YOUR-SERVICE-xxxxx.us-central1.run.app
